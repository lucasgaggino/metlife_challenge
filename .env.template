# ========== DATABASE CONFIGURATION ==========
DB_HOST=postgres
DB_PORT=5432
DB_NAME=metlife_db
DB_USER=metlife_user
DB_PASSWORD=change_this_in_production_please

# ========== ML PIPELINE CONFIGURATION ==========
# Entorno MLOps: sandbox (default, pruebas) | prod (registry/experiment _prod en MLflow)
ML_ENV=sandbox

# Parametros ML (modelo, umbrales, HP grid): editar config.yaml en la raiz del repo
# Estas variables OPCIONALMENTE overridean config.yaml:
LOG_LEVEL=INFO
HYPERPARAM_ITERATIONS=50
CV_FOLDS=5
SCORING_SAMPLE_SIZE=10

# ========== MLFLOW CONFIGURATION ==========
# Dentro de Docker el tracking server es http://mlflow:5000; en local usar http://localhost:5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=metlife_insurance
MLFLOW_MODEL_NAME=metlife_insurance_xgb
# En prod (ML_ENV=prod o ml_pipeline_prod): metlife_insurance_prod / metlife_insurance_xgb_prod
# Modo online (opcional, ver README.md §3.8 y config.yaml): ONLINE_N_SAMPLES ONLINE_RATE_PER_SECOND ONLINE_MONITORING_WINDOW_SIZE ONLINE_MONITORING_MAX_SAMPLES
# Base de datos backend de MLflow (separada de la app)
MLFLOW_DB_NAME=mlflow_db

# ========== GRAFANA CONFIGURATION ==========
# Credenciales del admin de Grafana (UI en http://localhost:3000)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ========== BUILD INFO (Optional) ==========
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
VERSION=1.0.0